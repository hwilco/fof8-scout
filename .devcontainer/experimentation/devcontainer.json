{
    "name": "FOF8 Experimentation",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--env-file", ".devcontainer/.env",
        "--gpus", "all"
    ],
    "mounts": [
        "source=${localEnv:HOME}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,consistency=cached",
        "source=/mnt/c/Users/${localEnv:USER}/.ssh,target=/home/vscode/.ssh-host,type=bind,readonly,consistency=cached"
    ],
    "containerEnv": {
        "EDITOR": "nano",
        "HOST_USER": "${localEnv:USER}",
        "GIT_CONFIG_COUNT": "1",
        "GIT_CONFIG_KEY_0": "safe.directory",
        "GIT_CONFIG_VALUE_0": "*"
    },
    "customizations": {
        "vscode": {
            "settings": {
                // The .venv lives outside the project dir (see Dockerfile), so we must
                // point VS Code to it explicitly rather than relying on auto-discovery.
                "python.defaultInterpreterPath": "/workspaces/.venv/bin/python"
            },
            "extensions": [
                "ms-toolsai.jupyter",
                "ms-python.python",
                "charliermarsh.ruff",
                "tamasfe.even-better-toml"
            ]
        }
    },
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    // Only install the experimentation package, but include the root dev tools
    "postCreateCommand": "bash .devcontainer/experimentation/setup.sh",
    "remoteUser": "vscode",
    "updateRemoteUserUID": true
}
