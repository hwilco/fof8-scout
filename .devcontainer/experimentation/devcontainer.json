{
    "name": "FOF8 Experimentation",
    "build": {
        "dockerfile": "Dockerfile",
        "context": ".."
    },
    "runArgs": [
        "--env-file", ".devcontainer/.env",
        "--gpus", "all"
    ],
    "containerEnv": {
        "EDITOR": "nano",
        "GIT_CONFIG_COUNT": "1",
        "GIT_CONFIG_KEY_0": "safe.directory",
        "GIT_CONFIG_VALUE_0": "*"
    },
    "features": {
        "ghcr.io/devcontainers/features/python:1": {
            "version": "3.12"
        }
    },
    "customizations": {
        "vscode": {
            "settings": {
                // The .venv lives outside the project dir (see Dockerfile), so we must
                // point VS Code to it explicitly rather than relying on auto-discovery.
                "python.defaultInterpreterPath": "/workspaces/.venv/bin/python"
            },
            "extensions": [
                "ms-toolsai.jupyter",
                "ms-python.python",
                "charliermarsh.ruff",
                "tamasfe.even-better-toml"
            ]
        }
    },
    "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",
    // Only install the experimentation package, but include the root dev tools
    "postCreateCommand": "bash .devcontainer/experimentation/setup.sh",
    "remoteUser": "vscode"
}
